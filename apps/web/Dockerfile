FROM node:20-alpine AS builder

ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"

RUN corepack enable

WORKDIR /app

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY apps/web/package.json apps/web/package.json
COPY apps/web/scripts apps/web/scripts

RUN pnpm install --filter web... --frozen-lockfile

COPY apps/web apps/web

ARG NEXT_PUBLIC_APP_URL
ARG NEXT_PUBLIC_SUPABASE_URL
ARG NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY
ARG NEXT_PUBLIC_MCP_BASE_URL
ARG CONTROL_PLANE_API_BASE_URL
ARG CONTROL_PLANE_INTERNAL_SECRET
ARG PUBLIC_MCP_BASE_URL
ARG DEPLOYMENT_VERSION
ARG NEXT_SERVER_ACTIONS_ENCRYPTION_KEY

ENV NEXT_PUBLIC_APP_URL=$NEXT_PUBLIC_APP_URL
ENV NEXT_PUBLIC_SUPABASE_URL=$NEXT_PUBLIC_SUPABASE_URL
ENV NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=$NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY
ENV NEXT_PUBLIC_MCP_BASE_URL=$NEXT_PUBLIC_MCP_BASE_URL
ENV CONTROL_PLANE_API_BASE_URL=$CONTROL_PLANE_API_BASE_URL
ENV CONTROL_PLANE_INTERNAL_SECRET=$CONTROL_PLANE_INTERNAL_SECRET
ENV PUBLIC_MCP_BASE_URL=$PUBLIC_MCP_BASE_URL
ENV DEPLOYMENT_VERSION=$DEPLOYMENT_VERSION
ENV NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=$NEXT_SERVER_ACTIONS_ENCRYPTION_KEY

RUN pnpm --dir apps/web build

FROM node:20-alpine AS runner

ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"
ENV NODE_ENV=production
ENV PORT=3000

RUN corepack enable

WORKDIR /app

COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/apps/web ./apps/web

WORKDIR /app/apps/web

EXPOSE 3000

CMD ["pnpm", "start"]
