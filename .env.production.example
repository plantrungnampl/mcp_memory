APP_ENV=production
LOG_LEVEL=info

NEXT_PUBLIC_APP_URL=https://app.example.com
NEXT_PUBLIC_DOCS_URL=https://docs.example.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_me
NEXT_PUBLIC_MCP_BASE_URL=https://api.example.com
PUBLIC_MCP_BASE_URL=https://api.example.com
DEPLOYMENT_VERSION=2026-03-08-release-001
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=replace-with-base64-32-byte-key

CONTROL_PLANE_API_BASE_URL=https://api.example.com
CONTROL_PLANE_INTERNAL_SECRET=replace-with-32-plus-random-chars
PUBLIC_WEB_URL=https://app.example.com
ALLOWED_ORIGINS=https://app.example.com

DATABASE_URL=postgresql+asyncpg://postgres:replace-me@postgres.example.com:5432/viberecall
TOKEN_PEPPER=replace-with-32-plus-random-chars

FALKORDB_HOST=falkordb
FALKORDB_PORT=6379
FALKORDB_USERNAME=
FALKORDB_PASSWORD=
FALKORDB_GRAPH_PREFIX=vr-

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

MEMORY_BACKEND=falkordb
KV_BACKEND=redis
QUEUE_BACKEND=celery

GRAPHITI_API_KEY=
GRAPHITI_LLM_MODEL=gpt-4.1-mini
GRAPHITI_EMBEDDER_MODEL=text-embedding-3-small
GRAPHITI_MCP_BRIDGE_MODE=legacy
GRAPHITI_TELEMETRY_ENABLED=false

OBJECT_STORAGE_MODE=local
OBJECT_LOCAL_DIR=.runtime-objects
OBJECT_BUCKET=
OBJECT_ENDPOINT=
OBJECT_REGION=auto
OBJECT_ACCESS_KEY_ID=
OBJECT_SECRET_ACCESS_KEY=
OBJECT_FORCE_PATH_STYLE=true
RAW_EPISODE_INLINE_MAX_BYTES=65536
INLINE_MIGRATION_DB_SIZE_THRESHOLD_BYTES=21474836480

INDEX_REPO_ALLOWED_ROOTS=/app
INDEX_REMOTE_GIT_ENABLED=false
RATE_LIMIT_TOKEN_CAPACITY=60
RATE_LIMIT_PROJECT_CAPACITY=300
RATE_LIMIT_WINDOW_SECONDS=60
RECENT_EPISODE_WINDOW_SECONDS=300

EXPORT_STORAGE_MODE=local
EXPORT_LOCAL_DIR=.runtime-exports
EXPORT_URL_TTL_SECONDS=3600
EXPORT_SIGNING_SECRET=replace-with-32-plus-random-chars

STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_WEBHOOK_TOLERANCE_SECONDS=300

SUPABASE_SERVICE_ROLE_KEY=replace-me
